<Window x:Class="WarehouseVisualizer.Views.EditMaterialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:models="clr-namespace:WarehouseVisualizer.Models"
        Title="Редактирование материала" 
        Height="450" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <ObjectDataProvider x:Key="MaterialTypeValues" 
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:MaterialType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource EnterpriseTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="{StaticResource EnterpriseTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource EnterpriseBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="{StaticResource EnterpriseTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource EnterpriseBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource EnterpriseBackgroundBrush}">
        <!-- Основной контейнер -->
        <Border Margin="16" Style="{StaticResource EnterpriseCard}">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="20"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Border Grid.Row="0" 
                        Background="{StaticResource EnterpriseSurfaceBrush}" 
                        BorderBrush="{StaticResource EnterpriseBorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="8,8,0,0" 
                        Padding="16,12">
                    <TextBlock Text="Редактирование материала" 
                               Foreground="{StaticResource EnterpriseTextBrush}" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </Border>

                <!-- Форма -->
                <StackPanel Grid.Row="1" Margin="16">
                    <TextBlock Text="Название материала" FontWeight="Medium"/>
                    <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Тип материала" FontWeight="Medium"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource MaterialTypeValues}}" 
                              SelectedItem="{Binding Type, Mode=TwoWay}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Количество" FontWeight="Medium"/>
                            <TextBox Text="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Единица измерения" FontWeight="Medium"/>
                            <TextBox Text="{Binding Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Например: шт., м, кг, л"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Кнопки -->
                <Border Grid.Row="2" 
                        Background="{StaticResource EnterpriseSurfaceBrush}" 
                        BorderBrush="{StaticResource EnterpriseBorderBrush}" 
                        BorderThickness="0,1,0,0"
                        Padding="16,12" 
                        CornerRadius="0,0,8,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Сохранить" 
                                Style="{StaticResource EnterpriseButton}"
                                Click="SaveButton_Click"
                                IsDefault="True">
                        </Button>
                        <Button Content="Отмена" 
                                Style="{StaticResource EnterpriseOutlineButton}"
                                Margin="8,0,0,0"
                                IsCancel="True"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
