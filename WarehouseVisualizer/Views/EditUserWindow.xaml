<Window x:Class="WarehouseVisualizer.Views.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:models="clr-namespace:WarehouseVisualizer.Models"
        xmlns:conv="clr-namespace:WarehouseVisualizer.Converters"
        Title="Редактирование пользователя" 
        Height="650" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <conv:BoolToNewUserConverter x:Key="BoolToNewUserConverter"/>

        <ObjectDataProvider x:Key="UserRoleValues" 
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:UserRole"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#343A40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#343A40"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#343A40"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <!-- Основной контейнер -->
        <Border Margin="16" Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="20"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Border Grid.Row="0" 
                        Background="#4A6FA5" 
                        CornerRadius="8,8,0,0" 
                        Padding="16,12">
                    <TextBlock Text="{Binding IsNewUser, Converter={StaticResource BoolToNewUserConverter}, 
                                     StringFormat='{}{0} пользователя'}" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </Border>

                <!-- Форма -->
                <StackPanel Grid.Row="1" Margin="16">
                    <TextBlock Text="Логин" FontWeight="Medium"/>
                    <TextBox Text="{Binding User.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsNewUser}"/>

                    <TextBlock Text="Пароль" FontWeight="Medium"/>
                    <PasswordBox x:Name="PasswordBox" 
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <TextBlock Text="Подтверждение пароля" FontWeight="Medium"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                    <TextBlock Text="ФИО" FontWeight="Medium"/>
                    <TextBox Text="{Binding User.FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Роль" FontWeight="Medium"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource UserRoleValues}}" 
                              SelectedItem="{Binding User.Role, Mode=TwoWay}"
                              IsEnabled="{Binding CanChangeRole}"/>

                    <CheckBox Content="Активен" 
                              IsChecked="{Binding User.IsActive, Mode=TwoWay}"
                              Margin="0,10,0,0"
                              IsEnabled="{Binding CanDeactivate}"/>
                </StackPanel>

                <!-- Кнопки -->
                <Border Grid.Row="2" 
                        Background="#F8F9FA" 
                        BorderBrush="#E9ECEF" 
                        BorderThickness="0,1,0,0"
                        Padding="16,12" 
                        CornerRadius="0,0,8,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Сохранить" 
                                Background="#4A6FA5" 
                                Foreground="White"
                                Click="SaveButton_Click"
                                IsDefault="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3A5A90"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Отмена" 
                                Background="Transparent" 
                                Foreground="#6C757D"
                                BorderBrush="#DEE2E6"
                                BorderThickness="1"
                                Margin="8,0,0,0"
                                IsCancel="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8F9FA"/>
                                            <Setter Property="BorderBrush" Value="#4A6FA5"/>
                                            <Setter Property="Foreground" Value="#4A6FA5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>