<Window x:Class="WarehouseVisualizer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:conv="clr-namespace:WarehouseVisualizer.Converters"
        Title="Интеллектуальная система управления складом"
        Height="850" Width="1450"
        MinWidth="1120" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        x:Name="mainWindow">

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:UserRoleToDescriptionConverter x:Key="UserRoleToDescriptionConverter"/>
        <conv:MaterialTypeToBrushConverter x:Key="MaterialTypeToBrushConverter"/>
        <conv:StringEqualsToVisibilityConverter x:Key="PageVisibilityConverter"/>
        <conv:CellOverlayBrushConverter x:Key="CellOverlayBrushConverter"/>
        <conv:NotificationPriorityBrushConverter x:Key="NotificationPriorityBrushConverter"/>
        <conv:EnumRussianNameConverter x:Key="EnumRussianNameConverter"/>

        <ContextMenu x:Key="CellContextMenu">
            <MenuItem Header="Редактировать" Command="{Binding DataContext.EditCellCommand, Source={x:Reference mainWindow}}" CommandParameter="{Binding}" IsEnabled="{Binding HasMaterial}"/>
            <MenuItem Header="Очистить" Command="{Binding DataContext.ClearCellCommand, Source={x:Reference mainWindow}}" CommandParameter="{Binding}" IsEnabled="{Binding HasMaterial}"/>
            <Separator/>
            <MenuItem Header="История" Command="{Binding DataContext.NavigateCommand, Source={x:Reference mainWindow}}" CommandParameter="Аналитика и аудит" IsEnabled="{Binding DataContext.CanViewAudit, Source={x:Reference mainWindow}}"/>
            <MenuItem Header="Авторазмещение" Command="{Binding DataContext.FindBestCellCommand, Source={x:Reference mainWindow}}"/>
        </ContextMenu>

        <ContextMenu x:Key="MaterialContextMenu">
            <MenuItem Header="Редактировать" Command="{Binding DataContext.EditMaterialCommand, Source={x:Reference mainWindow}}" CommandParameter="{Binding}"/>
            <MenuItem Header="Удалить" Command="{Binding DataContext.DeleteMaterialCommand, Source={x:Reference mainWindow}}" CommandParameter="{Binding}"/>
            <Separator/>
            <MenuItem Header="Отчёт по материалу" Command="{Binding DataContext.GenerateMaterialReportCommand, Source={x:Reference mainWindow}}" CommandParameter="{Binding}"/>
            <MenuItem Header="Авторазмещение" Command="{Binding DataContext.FindBestCellCommand, Source={x:Reference mainWindow}}"/>
        </ContextMenu>

        <DataTemplate x:Key="MaterialListItemTemplate">
            <Border Padding="10" Margin="0,0,0,6" Background="#172033" BorderBrush="#27364F" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{Binding Type, Converter={StaticResource MaterialTypeToBrushConverter}}" CornerRadius="3"/>
                    <StackPanel Grid.Column="1" Margin="10,0">
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource EnterpriseTextBrush}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Border Background="#22304A" CornerRadius="8" Padding="7,2" Margin="0,0,6,0">
                                <TextBlock Text="{Binding Type, Converter={StaticResource EnumRussianNameConverter}}" Foreground="{StaticResource EnterpriseAccentBrush}" FontSize="11"/>
                            </Border>
                            <TextBlock Text="{Binding Quantity, StringFormat='Кол-во {0}'}" Foreground="{StaticResource EnterpriseMutedTextBrush}" FontSize="11"/>
                            <TextBlock Text="{Binding Unit}" Foreground="{StaticResource EnterpriseMutedTextBrush}" FontSize="11" Margin="3,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Выбрать" Click="QuickDragButton_Click" Tag="{Binding}" Style="{StaticResource EnterpriseOutlineButton}" Padding="8,3" ToolTip="После выбора нажмите свободную ячейку на карте или перетащите материал drag and drop"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="NotificationTemplate">
            <Border Padding="10" Margin="0,0,0,8" Background="#172033" BorderBrush="{Binding Priority, Converter={StaticResource NotificationPriorityBrushConverter}}" BorderThickness="1" CornerRadius="8">
                <DockPanel>
                    <Button Content="Прочитано" Command="{Binding DataContext.MarkNotificationAsReadCommand, Source={x:Reference mainWindow}}" CommandParameter="{Binding}" Style="{StaticResource EnterpriseOutlineButton}" DockPanel.Dock="Right" Padding="8,2"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="8" Height="8" Background="{Binding Priority, Converter={StaticResource NotificationPriorityBrushConverter}}" CornerRadius="4" Margin="0,4,8,0"/>
                            <TextBlock Text="{Binding Type, Converter={StaticResource EnumRussianNameConverter}}" Foreground="{StaticResource EnterpriseAccentBrush}" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}" Foreground="{StaticResource EnterpriseMutedTextBrush}" FontSize="11" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Message}" Foreground="{StaticResource EnterpriseTextBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource EnterpriseBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0B1220" BorderBrush="#1F2A44" BorderThickness="0,0,1,0">
            <DockPanel Margin="16">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="СКЛАД PRO" Foreground="{StaticResource EnterpriseAccentBrush}" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="Интеллектуальная система управления складом" Foreground="{StaticResource EnterpriseMutedTextBrush}" TextWrapping="Wrap" Margin="0,2,0,18"/>

                    <Button Content="Карта склада" Command="{Binding NavigateCommand}" CommandParameter="Карта склада" Style="{StaticResource SidebarButton}"/>
                    <Button Content="Панель управления" Command="{Binding NavigateCommand}" CommandParameter="Панель управления" Style="{StaticResource SidebarButton}"/>
                    <Button Content="Материалы" Command="{Binding NavigateCommand}" CommandParameter="Материалы" Style="{StaticResource SidebarButton}"/>
                    <Button Content="Отчёты" Command="{Binding NavigateCommand}" CommandParameter="Отчёты" Style="{StaticResource SidebarButton}" Visibility="{Binding CanViewReports, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="Уведомления" Command="{Binding NavigateCommand}" CommandParameter="Уведомления" Style="{StaticResource SidebarButton}"/>
                    <Button Content="Аналитика и аудит" Command="{Binding NavigateCommand}" CommandParameter="Аналитика и аудит" Style="{StaticResource SidebarButton}" Visibility="{Binding CanViewAudit, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="Настройки" Command="{Binding NavigateCommand}" CommandParameter="Настройки" Style="{StaticResource SidebarButton}" Visibility="{Binding CanViewSettings, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Border Style="{StaticResource EnterpriseCard}" Padding="12">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentUser.FullName}" Foreground="{StaticResource EnterpriseTextBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CurrentUser.Role, Converter={StaticResource UserRoleToDescriptionConverter}}" Foreground="{StaticResource EnterpriseMutedTextBrush}" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Button Content="Выйти" Command="{Binding LogoutCommand}" Style="{StaticResource EnterpriseOutlineButton}" Margin="6"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="76"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="34"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource EnterpriseSurfaceBrush}" BorderBrush="#1F2A44" BorderThickness="0,0,0,1">
                <Grid Margin="22,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActivePage}" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="Операции склада, аналитика и интеллектуальное размещение" Style="{StaticResource MutedText}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#172033" BorderBrush="#27364F" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,10,0">
                            <TextBlock Text="{Binding CurrentTimeText}" Foreground="{StaticResource EnterpriseTextBrush}" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#172033" BorderBrush="#27364F" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,10,0">
                            <TextBlock Text="{Binding UnreadNotificationsCount, StringFormat='Уведомления {0}'}" Foreground="{StaticResource EnterpriseAmberBrush}" FontWeight="SemiBold"/>
                        </Border>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding CanEditMaterials, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Content="Сохранить"
                                    Command="{Binding SaveDataCommand}"
                                    Style="{StaticResource EnterpriseButton}"
                                    ToolTip="Сохранить карту склада и материалы в базе данных"/>
                            <Button Content="Загрузить"
                                    Command="{Binding LoadDataCommand}"
                                    Style="{StaticResource EnterpriseOutlineButton}"
                                    ToolTip="Загрузить склад из базы данных"/>
                        </StackPanel>
                        <Button Content="Создать демо-данные" Command="{Binding GenerateDemoDataCommand}" Style="{StaticResource EnterpriseButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="16">
                <Grid Visibility="{Binding ActivePage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter='Карта склада'}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource EnterpriseCard}" Padding="0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#111827" BorderBrush="#27364F" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0" Padding="12">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Увеличить" Command="{Binding ZoomInCommand}" Style="{StaticResource EnterpriseOutlineButton}"/>
                                        <Button Content="Уменьшить" Command="{Binding ZoomOutCommand}" Style="{StaticResource EnterpriseOutlineButton}"/>
                                        <Button Content="Сброс" Command="{Binding ResetMapViewCommand}" Style="{StaticResource EnterpriseOutlineButton}"/>
                                        <Separator Width="12" Opacity="0"/>
                                        <CheckBox Content="Тепловая карта" IsChecked="{Binding IsHeatmapEnabled}" Foreground="{StaticResource EnterpriseTextBrush}" VerticalAlignment="Center" Margin="6,0"/>
                                        <ComboBox SelectedValue="{Binding HeatmapMode}" SelectedValuePath="Content" Width="190" Style="{StaticResource ModernComboBox}" Margin="6,0">
                                            <ComboBoxItem Content="Заполненность"/>
                                            <ComboBoxItem Content="Активность перемещений"/>
                                            <ComboBoxItem Content="Риск низкого остатка"/>
                                            <ComboBoxItem Content="Зоны высокой нагрузки"/>
                                            <ComboBoxItem Content="Плотность категорий"/>
                                        </ComboBox>
                                        <Slider Minimum="0.15" Maximum="0.85" Value="{Binding HeatmapOpacity}" Width="120" Margin="8,0"/>
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right" Content="Найти лучшую ячейку" Command="{Binding FindBestCellCommand}" Style="{StaticResource EnterpriseButton}"/>
                                </DockPanel>
                            </Border>

                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#0F172A">
                                <Grid Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding MapZoom}" ScaleY="{Binding MapZoom}"/>
                                    </Grid.LayoutTransform>
                                    <ItemsControl ItemsSource="{Binding Warehouse.Cells}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="{Binding Warehouse.Columns}" Rows="{Binding Warehouse.Rows}"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CellBorderStyle}"
                                                        ContextMenu="{StaticResource CellContextMenu}"
                                                        AllowDrop="True"
                                                        Drop="Cell_Drop"
                                                        MouseLeftButtonDown="Cell_MouseLeftButtonDown"
                                                        ToolTip="{Binding Location}">
                                                    <Grid Width="92" Height="92" Background="#111827">
                                                        <Border Opacity="{Binding DataContext.HeatmapOpacity, RelativeSource={RelativeSource AncestorType=Window}}">
                                                            <Border.Background>
                                                                <MultiBinding Converter="{StaticResource CellOverlayBrushConverter}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.SuggestedCell" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    <Binding Path="DataContext.IsHeatmapEnabled" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    <Binding Path="DataContext.HeatmapMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                </MultiBinding>
                                                            </Border.Background>
                                                        </Border>
                                                        <Border Margin="5" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Background="#101827">
                                                            <Grid>
                                                                <TextBlock Text="{Binding Location}" Foreground="{StaticResource EnterpriseMutedTextBrush}" FontSize="10" Margin="5"/>
                                                                <StackPanel VerticalAlignment="Center" Margin="6">
                                                                    <TextBlock Text="{Binding Material.Name}" Foreground="{StaticResource EnterpriseTextBrush}" FontSize="10" TextWrapping="Wrap" TextAlignment="Center"/>
                                                                    <TextBlock Text="{Binding Material.Quantity}" Foreground="{StaticResource EnterpriseAccentBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource EnterpriseCard}">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top">
                                        <TextBlock Text="Материалы для размещения" Style="{StaticResource SectionTitleText}"/>
                                        <TextBlock Text="Выберите материал или перетащите его на свободную ячейку карты." Style="{StaticResource MutedText}" Margin="0,4,0,8"/>
                                    </StackPanel>
                                    <ListBox x:Name="MapMaterialsList"
                                             ItemsSource="{Binding AvailableMaterials}"
                                             SelectedItem="{Binding SelectedMaterial}"
                                             ItemTemplate="{StaticResource MaterialListItemTemplate}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             MaxHeight="220"
                                             PreviewMouseMove="MaterialsList_PreviewMouseMove"/>
                                </DockPanel>
                            </Border>

                            <Border Style="{StaticResource EnterpriseCard}">
                                <StackPanel>
                                    <TextBlock Text="Детали ячейки / материала" Style="{StaticResource SectionTitleText}"/>
                                    <TextBlock Text="{Binding SelectedCellLocation}" Foreground="{StaticResource EnterpriseAccentBrush}" FontSize="18" FontWeight="Bold" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding DetailsMaterial.Name, TargetNullValue='Материал не выбран'}" Foreground="{StaticResource EnterpriseTextBrush}" FontSize="16" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Категория: " Foreground="{StaticResource EnterpriseMutedTextBrush}"/>
                                        <TextBlock Text="{Binding DetailsMaterial.Type, Converter={StaticResource EnumRussianNameConverter}}" Foreground="{StaticResource EnterpriseMutedTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding DetailsMaterial.Quantity, StringFormat='Количество: {0}'}" Foreground="{StaticResource EnterpriseMutedTextBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="Редактировать" Command="{Binding EditCellCommand}" CommandParameter="{Binding SelectedCell}" Style="{StaticResource EnterpriseOutlineButton}"/>
                                        <Button Content="История" Command="{Binding NavigateCommand}" CommandParameter="Аналитика и аудит" Style="{StaticResource EnterpriseOutlineButton}" Visibility="{Binding CanViewAudit, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Button Content="Показать QR" Command="{Binding GenerateQrCommand}" Style="{StaticResource EnterpriseOutlineButton}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource EnterpriseCard}">
                                <StackPanel>
                                    <TextBlock Text="Модуль авторазмещения" Style="{StaticResource SectionTitleText}"/>
                                    <TextBlock Text="{Binding SmartPlacementScore, StringFormat='Оценка пригодности: {0}%'}" Foreground="{StaticResource EnterpriseGreenBrush}" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                                    <ProgressBar Value="{Binding SmartPlacementScore, Mode=OneWay}" Maximum="100" Height="10" Margin="0,8,0,8"/>
                                    <TextBlock Text="{Binding SmartPlacementReason}" Foreground="{StaticResource EnterpriseMutedTextBrush}" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="Подтвердить" Command="{Binding ConfirmPlacementCommand}" Style="{StaticResource EnterpriseButton}"/>
                                        <Button Content="Альтернатива" Command="{Binding FindAlternativeCommand}" Style="{StaticResource EnterpriseOutlineButton}"/>
                                        <Button Content="Отклонить" Command="{Binding RejectPlacementCommand}" Style="{StaticResource EnterpriseOutlineButton}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource EnterpriseCard}">
                                <StackPanel>
                                    <TextBlock Text="Предпросмотр QR-этикетки" Style="{StaticResource SectionTitleText}"/>
                                    <Border Background="White" CornerRadius="8" Padding="10" Margin="0,10,0,0" HorizontalAlignment="Left">
                                        <Image Source="{Binding SelectedQrImage}" Width="170" Height="170" Stretch="Uniform"/>
                                    </Border>
                                    <TextBlock Text="{Binding SelectedQrCodeText}" Foreground="{StaticResource EnterpriseMutedTextBrush}" Margin="0,8,0,0"/>
                                    <Button Content="Обновить QR" Command="{Binding GenerateQrCommand}" Style="{StaticResource EnterpriseOutlineButton}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource EnterpriseCard}">
                                <StackPanel>
                                    <TextBlock Text="Легенда тепловой карты" Style="{StaticResource SectionTitleText}"/>
                                    <TextBlock Text="Зелёный: свободная ёмкость" Foreground="{StaticResource EnterpriseGreenBrush}" Margin="0,8,0,0"/>
                                    <TextBlock Text="Жёлтый: занято / активно" Foreground="{StaticResource EnterpriseAmberBrush}"/>
                                    <TextBlock Text="Красный: риск низкого остатка" Foreground="{StaticResource EnterpriseRedBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <ScrollViewer Visibility="{Binding ActivePage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter='Панель управления'}">
                    <StackPanel>
                        <UniformGrid Columns="4">
                            <Border Style="{StaticResource EnterpriseCard}"><StackPanel><TextBlock Text="Всего материалов" Style="{StaticResource MutedText}"/><TextBlock Text="{Binding AvailableMaterials.Count}" FontSize="30" Foreground="{StaticResource EnterpriseTextBrush}" FontWeight="Bold"/></StackPanel></Border>
                            <Border Style="{StaticResource EnterpriseCard}"><StackPanel><TextBlock Text="Заполненность" Style="{StaticResource MutedText}"/><TextBlock Text="{Binding WarehouseReport.OccupancyPercentage, Mode=OneWay, StringFormat='{}{0:F1}%'}" FontSize="30" Foreground="{StaticResource EnterpriseAccentBrush}" FontWeight="Bold"/><ProgressBar Value="{Binding WarehouseReport.OccupancyPercentage, Mode=OneWay}" Maximum="100"/></StackPanel></Border>
                            <Border Style="{StaticResource EnterpriseCard}"><StackPanel><TextBlock Text="Свободные ячейки" Style="{StaticResource MutedText}"/><TextBlock Text="{Binding FreeCellsCount}" FontSize="30" Foreground="{StaticResource EnterpriseGreenBrush}" FontWeight="Bold"/></StackPanel></Border>
                            <Border Style="{StaticResource EnterpriseCard}"><StackPanel><TextBlock Text="Низкий остаток" Style="{StaticResource MutedText}"/><TextBlock Text="{Binding LowStockMaterialsCount}" FontSize="30" Foreground="{StaticResource EnterpriseRedBrush}" FontWeight="Bold"/></StackPanel></Border>
                            <Border Style="{StaticResource EnterpriseCard}"><StackPanel><TextBlock Text="Операций за день" Style="{StaticResource MutedText}"/><TextBlock Text="{Binding DailyOperationsCount}" FontSize="28" Foreground="{StaticResource EnterpriseTextBrush}" FontWeight="Bold"/></StackPanel></Border>
                            <Border Style="{StaticResource EnterpriseCard}"><StackPanel><TextBlock Text="Операций за месяц" Style="{StaticResource MutedText}"/><TextBlock Text="{Binding MonthlyOperationsCount}" FontSize="28" Foreground="{StaticResource EnterpriseTextBrush}" FontWeight="Bold"/></StackPanel></Border>
                            <Border Style="{StaticResource EnterpriseCard}"><StackPanel><TextBlock Text="Непрочитанные уведомления" Style="{StaticResource MutedText}"/><TextBlock Text="{Binding UnreadNotificationsCount}" FontSize="28" Foreground="{StaticResource EnterpriseAmberBrush}" FontWeight="Bold"/></StackPanel></Border>
                            <Border Style="{StaticResource EnterpriseCard}"><StackPanel><TextBlock Text="Активные пользователи" Style="{StaticResource MutedText}"/><TextBlock Text="{Binding ActiveUsersCount}" FontSize="28" Foreground="{StaticResource EnterprisePurpleBrush}" FontWeight="Bold"/></StackPanel></Border>
                        </UniformGrid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource EnterpriseCard}">
                                <StackPanel>
                                    <TextBlock Text="Топ категорий" Style="{StaticResource SectionTitleText}"/>
                                    <ListView ItemsSource="{Binding ReportItems}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource EnterpriseTextBrush}" MaxHeight="260">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Категория" Width="120">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Type, Converter={StaticResource EnumRussianNameConverter}}"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Количество" DisplayMemberBinding="{Binding Quantity}" Width="90"/>
                                                <GridViewColumn Header="Ячейки" DisplayMemberBinding="{Binding CellCount}" Width="70"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource EnterpriseCard}">
                                <StackPanel>
                                    <TextBlock Text="Последняя активность" Style="{StaticResource SectionTitleText}"/>
                                    <ListBox ItemsSource="{Binding ActivityFeed}" DisplayMemberPath="Details" Background="Transparent" BorderThickness="0" Foreground="{StaticResource EnterpriseTextBrush}" MaxHeight="260"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Grid Visibility="{Binding ActivePage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter='Материалы'}">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="420"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource EnterpriseCard}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Каталог материалов" Style="{StaticResource SectionTitleText}"/>
                                <TextBox Text="{Binding MaterialSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,10,0,6"/>
                                <DockPanel>
                                    <CheckBox Content="Только низкий остаток" IsChecked="{Binding ShowOnlyLowStock}" Foreground="{StaticResource EnterpriseTextBrush}"/>
                                    <Button Content="Сброс" Command="{Binding ResetMaterialFilterCommand}" Style="{StaticResource EnterpriseOutlineButton}" DockPanel.Dock="Right"/>
                                </DockPanel>
                            </StackPanel>
                            <ListBox x:Name="MaterialsList" ItemsSource="{Binding AvailableMaterials}" SelectedItem="{Binding SelectedMaterial}" ItemTemplate="{StaticResource MaterialListItemTemplate}" Background="Transparent" BorderThickness="0" PreviewMouseMove="MaterialsList_PreviewMouseMove"/>
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource EnterpriseCard}">
                        <StackPanel>
                            <TextBlock Text="Детали материала" Style="{StaticResource PageTitleText}"/>
                            <TextBlock Text="{Binding SelectedMaterial.Name, TargetNullValue='Выберите материал'}" FontSize="24" Foreground="{StaticResource EnterpriseAccentBrush}" Margin="0,14,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Категория: " Foreground="{StaticResource EnterpriseTextBrush}"/>
                                <TextBlock Text="{Binding SelectedMaterial.Type, Converter={StaticResource EnumRussianNameConverter}}" Foreground="{StaticResource EnterpriseTextBrush}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedMaterial.Quantity, StringFormat='Остаток: {0}'}" Foreground="{StaticResource EnterpriseTextBrush}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Статус: " Foreground="{StaticResource EnterpriseGreenBrush}"/>
                                <TextBlock Text="{Binding SelectedMaterial.Status, Converter={StaticResource EnumRussianNameConverter}}" Foreground="{StaticResource EnterpriseGreenBrush}"/>
                            </StackPanel>
                            <TextBlock Text="История перемещений и QR-этикетка синхронизируются с выбранным материалом." Style="{StaticResource MutedText}" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <ScrollViewer Visibility="{Binding ActivePage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter='Отчёты'}">
                    <StackPanel>
                        <Border Style="{StaticResource EnterpriseCard}">
                            <StackPanel>
                                <TextBlock Text="Центр отчётов" Style="{StaticResource PageTitleText}"/>
                                <TextBlock Text="Отчёты и обмен данными доступны администратору и аудитору." Style="{StaticResource MutedText}" Margin="0,4,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button Content="Отчёт"
                                            Command="{Binding ExportReportCommand}"
                                            Style="{StaticResource EnterpriseButton}"
                                            ToolTip="Экспорт отчёта склада в Excel"
                                            Visibility="{Binding CanExportReports, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Экспорт"
                                            Command="{Binding ExportMaterialsCommand}"
                                            Style="{StaticResource EnterpriseOutlineButton}"
                                            ToolTip="Экспорт материалов в Excel"
                                            Visibility="{Binding CanExportMaterialsProp, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Импорт"
                                            Command="{Binding ImportMaterialsCommand}"
                                            Style="{StaticResource EnterpriseOutlineButton}"
                                            ToolTip="Импорт материалов из Excel"
                                            Visibility="{Binding CanImportData, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Шаблон"
                                            Command="{Binding CreateTemplateCommand}"
                                            Style="{StaticResource EnterpriseOutlineButton}"
                                            ToolTip="Создать шаблон Excel для импорта"
                                            Visibility="{Binding CanCreateReports, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Visibility="{Binding ActivePage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter='Уведомления'}">
                    <Border Style="{StaticResource EnterpriseCard}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                <TextBlock Text="Центр уведомлений" Style="{StaticResource PageTitleText}" Width="260"/>
                                <Button Content="Отметить всё прочитанным" Command="{Binding MarkAllNotificationsAsReadCommand}" Style="{StaticResource EnterpriseOutlineButton}"/>
                            </StackPanel>
                            <ListView ItemsSource="{Binding Notifications}" ItemTemplate="{StaticResource NotificationTemplate}" Background="Transparent" BorderThickness="0"/>
                        </DockPanel>
                    </Border>
                </Grid>

                <ScrollViewer Visibility="{Binding ActivePage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter='Аналитика и аудит'}">
                    <StackPanel>
                        <Border Style="{StaticResource EnterpriseCard}" Visibility="{Binding CanManageBackups, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Активность системы" Style="{StaticResource PageTitleText}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="{Binding IsSimulationRunning, StringFormat='Демо-режим: {0}'}" Command="{Binding ToggleSimulationCommand}" Style="{StaticResource EnterpriseButton}"/>
                                    <TextBlock Text="{Binding SimulationEventsCount, StringFormat='Событий: {0}'}" Foreground="{StaticResource EnterpriseMutedTextBrush}" VerticalAlignment="Center" Margin="16,0"/>
                                </StackPanel>
                                <ListBox ItemsSource="{Binding ActivityFeed}" DisplayMemberPath="Details" Height="170" Margin="0,12,0,0" Background="Transparent" BorderThickness="0" Foreground="{StaticResource EnterpriseTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource EnterpriseCard}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Журнал действий" Style="{StaticResource PageTitleText}" Margin="0,0,0,12"/>
                                <ListView ItemsSource="{Binding History}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource EnterpriseTextBrush}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Время" DisplayMemberBinding="{Binding Timestamp}" Width="150"/>
                                            <GridViewColumn Header="Действие" Width="150">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ActionType, Converter={StaticResource EnumRussianNameConverter}}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Материал" DisplayMemberBinding="{Binding MaterialName}" Width="220"/>
                                            <GridViewColumn Header="Откуда" DisplayMemberBinding="{Binding FromLocation}" Width="90"/>
                                            <GridViewColumn Header="Куда" DisplayMemberBinding="{Binding ToLocation}" Width="90"/>
                                            <GridViewColumn Header="Пользователь" DisplayMemberBinding="{Binding UserName}" Width="130"/>
                                            <GridViewColumn Header="Причина" DisplayMemberBinding="{Binding Reason}" Width="260"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Visibility="{Binding ActivePage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter='Настройки'}">
                    <StackPanel>
                        <Border Style="{StaticResource EnterpriseCard}" Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Настройки склада" Style="{StaticResource PageTitleText}"/>
                                <TextBlock Text="Размер сетки склада. При изменении размера материалы в существующих ячейках сохраняются, если ячейки остаются в пределах новой сетки." Foreground="{StaticResource EnterpriseMutedTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <StackPanel Width="150" Margin="0,0,12,0">
                                        <TextBlock Text="Ряды" Style="{StaticResource MutedText}"/>
                                        <TextBox Text="{Binding Warehouse.Rows, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Width="150" Margin="0,0,12,0">
                                        <TextBlock Text="Колонки" Style="{StaticResource MutedText}"/>
                                        <TextBox Text="{Binding Warehouse.Columns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>
                                    <Button Content="Применить размер" Command="{Binding ApplyWarehouseSettingsCommand}" Style="{StaticResource EnterpriseButton}" VerticalAlignment="Bottom"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource EnterpriseCard}" Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Управление пользователями" Style="{StaticResource PageTitleText}"/>
                                <TextBlock Text="Создание пользователей, редактирование ролей и отключение доступа." Foreground="{StaticResource EnterpriseMutedTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                <Button Content="Открыть управление пользователями"
                                        Command="{Binding OpenUserManagementCommand}"
                                        Style="{StaticResource EnterpriseButton}"
                                        HorizontalAlignment="Left"
                                        Margin="0,14,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource EnterpriseCard}">
                            <StackPanel>
                                <TextBlock Text="Настройки / Центр резервного копирования" Style="{StaticResource PageTitleText}"/>
                                <TextBlock Text="Интерфейс центра резервного копирования: создание, восстановление, список копий и диалоги подтверждения подготовлены для следующего слоя сохранения." Foreground="{StaticResource EnterpriseMutedTextBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="Создать копию" Command="{Binding CreateBackupCommand}" Style="{StaticResource EnterpriseButton}"/>
                                    <Button Content="Восстановить" Command="{Binding RestoreBackupCommand}" Style="{StaticResource EnterpriseOutlineButton}"/>
                                    <Button Content="Удалить старую копию" Command="{Binding DeleteOldBackupCommand}" Style="{StaticResource EnterpriseOutlineButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <StatusBar Grid.Row="2" Background="#0B1220" BorderBrush="#1F2A44" BorderThickness="0,1,0,0">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource EnterpriseMutedTextBrush}"/>
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <TextBlock Text="{Binding WarehouseReport.OccupancyPercentage, StringFormat='Заполненность {0:F1}%'}" Foreground="{StaticResource EnterpriseAccentBrush}"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Grid>
</Window>
