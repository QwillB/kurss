<Window x:Class="WarehouseVisualizer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WarehouseVisualizer.ViewModels"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:conv="clr-namespace:WarehouseVisualizer.Converters"
        mc:Ignorable="d"
        Title="Warehouse Visualizer"
        Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
        MinWidth="1000" MinHeight="600"
        WindowState="Maximized"
        x:Name="mainWindow">

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:UserRoleToDescriptionConverter x:Key="UserRoleToDescriptionConverter"/>
        <conv:MaterialTypeToBrushConverter x:Key="MaterialTypeToBrushConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <!-- Шаблон для материала в ячейке -->
        <DataTemplate x:Key="MaterialTemplate">
            <Border Style="{StaticResource MaterialPanelStyle}"
                    ToolTip="{Binding Name}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Название материала -->
                    <TextBlock Grid.Row="0" 
                               Text="{Binding Name}" 
                               TextWrapping="Wrap" 
                               FontWeight="SemiBold" 
                               FontSize="10"
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               TextAlignment="Center" 
                               Margin="2"
                               Foreground="#333"/>

                    <!-- Количество и единица измерения -->
                    <Border Grid.Row="1" 
                            Background="White" 
                            CornerRadius="3" 
                            Padding="3,1"
                            Margin="2">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Quantity}" 
                                       FontSize="9" 
                                       FontWeight="Bold"
                                       Foreground="#333"/>
                            <TextBlock Text="{Binding Unit}" 
                                       FontSize="9" 
                                       Margin="2,0,0,0"
                                       Foreground="#666"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Контекстное меню для ячейки -->
        <ContextMenu x:Key="CellContextMenu">
            <MenuItem Header="✏️ Редактировать" 
                      Command="{Binding DataContext.EditCellCommand, Source={x:Reference mainWindow}}" 
                      CommandParameter="{Binding}"
                      IsEnabled="{Binding HasMaterial}"/>

            <MenuItem Header="🗑️ Очистить" 
                      Command="{Binding DataContext.ClearCellCommand, Source={x:Reference mainWindow}}" 
                      CommandParameter="{Binding}"
                      IsEnabled="{Binding HasMaterial}"/>

            <Separator/>

            <MenuItem Header="📋 Копировать название" 
                      Command="{x:Static ApplicationCommands.Copy}"
                      CommandParameter="{Binding Material.Name}"
                      IsEnabled="{Binding HasMaterial}"/>

            <MenuItem Header="📍 Копировать локацию" 
                      Command="{x:Static ApplicationCommands.Copy}"
                      CommandParameter="{Binding Location}"/>
        </ContextMenu>

        <!-- Контекстное меню для списка материалов -->
        <ContextMenu x:Key="MaterialContextMenu">
            <MenuItem Header="✏️ Редактировать" 
                      Command="{Binding DataContext.EditMaterialCommand, Source={x:Reference mainWindow}}"
                      CommandParameter="{Binding}"/>

            <MenuItem Header="🗑️ Удалить" 
                      Command="{Binding DataContext.DeleteMaterialCommand, Source={x:Reference mainWindow}}"
                      CommandParameter="{Binding}"/>

            <Separator/>

            <MenuItem Header="📋 Копировать название" 
                      Command="{x:Static ApplicationCommands.Copy}"
                      CommandParameter="{Binding Name}"/>

            <MenuItem Header="📊 Отчет по материалу"
                      Command="{Binding DataContext.GenerateMaterialReportCommand, Source={x:Reference mainWindow}}"
                      CommandParameter="{Binding}"/>
        </ContextMenu>

        <!-- Шаблон для уведомлений -->
        <DataTemplate x:Key="NotificationTemplate">
            <Border Style="{StaticResource NotificationStyle}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" 
                             Fill="{StaticResource InfoBrush}" 
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Message}" 
                               TextWrapping="Wrap" 
                               FontSize="12"
                               Foreground="{StaticResource DarkGrayBrush}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Шаблон для элементов списка материалов -->
        <DataTemplate x:Key="MaterialListItemTemplate">
            <Border Padding="8,6" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Индикатор типа материала -->
                    <Border Grid.Column="0" 
                            Width="12" 
                            Height="12" 
                            Margin="0,0,8,0"
                            CornerRadius="2"
                            Background="{Binding Type, Converter={StaticResource MaterialTypeToBrushConverter}}"
                            VerticalAlignment="Center"/>

                    <!-- Информация о материале -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Name}" 
                                   FontWeight="Medium"
                                   Foreground="{StaticResource DarkGrayBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding Type}" 
                                       FontSize="11" 
                                       Foreground="#666"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Quantity, StringFormat='{}{0} шт.'}" 
                                       FontSize="11" 
                                       Foreground="#666"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Кнопка быстрого доступа -->
                    <Button Grid.Column="2" 
                            Content="➔" 
                            Style="{StaticResource OutlineButton}"
                            Width="24" 
                            Height="24" 
                            Padding="0"
                            FontSize="10"
                            ToolTip="Перетащить на склад"
                            Cursor="Hand"
                            Tag="{Binding}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                <i:InvokeCommandAction Command="{Binding DataContext.StartMaterialDragCommand, 
                                                                   RelativeSource={RelativeSource AncestorType=Window}}"
                                                       CommandParameter="{Binding}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid Background="{StaticResource LightGrayBrush}">
        <!-- Главный контейнер -->
        <Border Margin="16" CornerRadius="8" Background="White">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="20"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая панель - склад -->
                <DockPanel Grid.Column="0" Margin="1">
                    <!-- Верхняя панель с пользователем -->
                    <Border DockPanel.Dock="Top" 
                            Background="{StaticResource PrimaryBrush}" 
                            Height="60"
                            CornerRadius="8,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Информация о пользователе -->
                            <StackPanel Orientation="Horizontal" 
                                        VerticalAlignment="Center" 
                                        Margin="20,0">
                                <Border Background="White" 
                                        CornerRadius="20" 
                                        Width="40" 
                                        Height="40"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="{Binding CurrentUser.Username, StringFormat={}{0:u}}" 
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="16"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="{Binding CurrentUser.FullName}" 
                                               Foreground="White" 
                                               FontWeight="SemiBold"
                                               FontSize="14"/>
                                    <TextBlock Text="{Binding CurrentUser.Role, Converter={StaticResource UserRoleToDescriptionConverter}}" 
                                               Foreground="White" 
                                               FontSize="12"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Кнопка выхода -->
                            <Button Grid.Column="1" 
                                    Content="Выйти" 
                                    Command="{Binding LogoutCommand}"
                                    Background="Transparent" 
                                    Foreground="White" 
                                    BorderBrush="White"
                                    BorderThickness="1"
                                    Padding="20,8"
                                    Margin="0,0,20,0"
                                    VerticalAlignment="Center"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Панель инструментов -->
                    <ToolBar DockPanel.Dock="Top" Style="{StaticResource ModernToolBar}" Height="70">
                        <StackPanel Orientation="Horizontal">
                            <!-- Размеры склада (только для админа) -->
                            <TextBlock Text="Размеры:" 
                   VerticalAlignment="Center" 
                   Margin="0,0,8,0"
                   Foreground="{StaticResource DarkGrayBrush}"
                   Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <Border Background="White" 
                CornerRadius="4" 
                Padding="4,0" 
                Margin="0,0,16,0"
                Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Ряды:" 
                           VerticalAlignment="Center" 
                           Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding Warehouse.Rows, UpdateSourceTrigger=PropertyChanged}" 
                         Width="40" 
                         Style="{StaticResource ModernTextBox}"
                         VerticalContentAlignment="Center"/>
                                    <TextBlock Text="Колонки:" 
                           VerticalAlignment="Center" 
                           Margin="8,0,4,0"/>
                                    <TextBox Text="{Binding Warehouse.Columns, UpdateSourceTrigger=PropertyChanged}" 
                         Width="40" 
                         Style="{StaticResource ModernTextBox}"
                         VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Separator Margin="16,0" Width="1" Background="#DEE2E6" VerticalAlignment="Stretch"/>

                            <!-- Основные действия (Сохранить/Загрузить) - для админа и кладовщика -->
                            <StackPanel Orientation="Horizontal" 
                    Visibility="{Binding CanEditMaterials, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Content="💾 Сохранить" 
                    Command="{Binding SaveDataCommand}" 
                    Style="{StaticResource PrimaryButton}"
                    ToolTip="Сохранить состояние склада"/>
                                <Button Content="📂 Загрузить" 
                    Command="{Binding LoadDataCommand}" 
                    Style="{StaticResource OutlineButton}"
                    ToolTip="Загрузить состояние склада"/>
                            </StackPanel>

                            <Separator Margin="16,0" Width="1" Background="#DEE2E6" VerticalAlignment="Stretch"/>

                            <!-- Отчеты и работа с данными -->
                            <StackPanel Orientation="Horizontal">
                                <!-- Отчет (для админа и аудитора) -->
                                <!-- Отчет (для админа и аудитора) -->
                                <Button Content="📊 Отчет" 
        Command="{Binding ExportReportCommand}"
        Style="{StaticResource PrimaryButton}"
        ToolTip="Экспорт отчета в Excel"
        Visibility="{Binding CanExportReports, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <!-- Экспорт материалов (для админа и аудитора) -->
                                <Button Content="📤 Экспорт" 
        Command="{Binding ExportMaterialsCommand}"
        Style="{StaticResource OutlineButton}"
        ToolTip="Экспорт материалов в Excel"
        Visibility="{Binding CanExportMaterialsProp, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <!-- Импорт материалов (для админа и аудитора) -->
                                <Button Content="📥 Импорт" 
        Command="{Binding ImportMaterialsCommand}"
        Style="{StaticResource OutlineButton}"
        ToolTip="Импорт материалов из Excel"
        Visibility="{Binding CanImportData, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <!-- Шаблон импорта (для админа и аудитора) -->
                                <Button Content="📋 Шаблон" 
        Command="{Binding CreateTemplateCommand}"
        Style="{StaticResource OutlineButton}"
        ToolTip="Создать шаблон для импорта"
        Visibility="{Binding CanCreateReports, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <!-- В панели инструментов добавьте: -->
                               
                            </StackPanel>

                            <Separator Margin="16,0" Width="1" Background="#DEE2E6" VerticalAlignment="Stretch"/>

                            <!-- Управление пользователями (только для админа) -->
                            <Button Content="👥 Пользователи" 
                Command="{Binding OpenUserManagementCommand}"
                Style="{StaticResource PrimaryButton}"
                ToolTip="Управление пользователями"
                Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </ToolBar>

                    <!-- Склад -->
                    <Border BorderBrush="#E9ECEF" BorderThickness="0,1,0,0" Background="White">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Auto" 
                                      Padding="20">
                            <ItemsControl ItemsSource="{Binding Warehouse.Cells}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="{Binding Warehouse.Columns}" 
                                                     Rows="{Binding Warehouse.Rows}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CellBorderStyle}"
                                                ContextMenu="{StaticResource CellContextMenu}"
                                                AllowDrop="True"
                                                Drop="Cell_Drop"
                                                MouseLeftButtonDown="Cell_MouseLeftButtonDown"
                                                ToolTip="{Binding Location}">

                                            <!-- Обработчик двойного клика -->
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="MouseDoubleClick">
                                                    <i:InvokeCommandAction Command="{Binding DataContext.EditCellCommand, 
                                                                           RelativeSource={RelativeSource AncestorType=Window}}"
                                                                           CommandParameter="{Binding}"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>

                                            <!-- Внутренний ContentControl -->
                                            <ContentControl Style="{StaticResource CellStyle}" 
                                                            Content="{Binding Material}"
                                                            ContentTemplate="{StaticResource MaterialTemplate}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </DockPanel>

                <!-- Правая панель -->
                <Grid Grid.Column="1" Background="{StaticResource LightGrayBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Панель добавления материалов -->
                    <!-- Панель добавления материалов -->
                    <Border Grid.Row="0" 
        Background="White" 
        Margin="8,8,8,4" 
        CornerRadius="6"
        Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Добавить материал" 
                       FontWeight="SemiBold" 
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,8"/>

                                <StackPanel Orientation="Horizontal">
                                    <ComboBox ItemsSource="{Binding AvailableMaterials}"
                          SelectedItem="{Binding SelectedMaterial}"
                          DisplayMemberPath="Name"
                          Width="160"
                          Margin="0,0,8,0"
                          Style="{StaticResource ModernComboBox}">
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Padding" Value="8"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ComboBoxItem">
                                                            <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource LightGrayBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource LightGrayBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                    </ComboBox>

                                    <TextBox Text="{Binding SelectedQuantity, UpdateSourceTrigger=PropertyChanged}"
                         Width="60"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,8,0"
                         IsEnabled="{Binding CanEditMaterials}"/>

                                    <!-- Кнопка "+" только для админа и кладовщика -->
                                    <Button Content="+" 
                        Command="{Binding AddNewMaterialCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Width="32"
                        ToolTip="Добавить новый материал"
                        Visibility="{Binding CanEditMaterials, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Grid.Column="1" 
                   Text="{Binding OccupiedCellsCount, StringFormat='Занято: {0}'}"
                   VerticalAlignment="Bottom"
                   Foreground="#666"
                   FontSize="12"/>
                        </Grid>
                    </Border>

                    <!-- Список материалов -->
                    <GroupBox Grid.Row="1" 
                              Header="Доступные материалы" 
                              Style="{StaticResource ModernGroupBox}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListBox x:Name="MaterialsList"
                                     ItemsSource="{Binding AvailableMaterials}" 
                                     SelectedItem="{Binding SelectedMaterial}"
                                     ItemTemplate="{StaticResource MaterialListItemTemplate}"
                                     Style="{StaticResource ModernListBox}"
                                     ContextMenu="{StaticResource MaterialContextMenu}"
                                     PreviewMouseMove="MaterialsList_PreviewMouseMove">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="ContextMenu" Value="{StaticResource MaterialContextMenu}"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <TextBlock Grid.Row="1" 
                                       Text="{Binding AvailableMaterials.Count, StringFormat='Всего: {0}'}"
                                       HorizontalAlignment="Right"
                                       Margin="0,8,0,0"
                                       Foreground="#666"
                                       FontSize="11"/>
                        </Grid>
                    </GroupBox>

                    <!-- История и уведомления -->
                    <TabControl Grid.Row="2" Margin="8,4,8,8" BorderThickness="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Name="Border" 
                                                    Background="Transparent" 
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    Margin="0,0,8,0">
                                                <ContentPresenter x:Name="ContentSite"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center"
                                                                  ContentSource="Header"
                                                                  Margin="12,8"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,2"/>
                                                    <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <TabItem Header="📋 История">
                            <ListView ItemsSource="{Binding History}" 
                                      DisplayMemberPath="Details"
                                      Style="{StaticResource ModernListBox}"
                                      BorderThickness="0"/>
                        </TabItem>

                        <TabItem Header="🔔 Уведомления">
                            <ListView ItemsSource="{Binding Notifications}" 
                                      ItemTemplate="{StaticResource NotificationTemplate}"
                                      Style="{StaticResource ModernListBox}"
                                      BorderThickness="0"/>
                        </TabItem>
                    </TabControl>

                    <!-- Статусная панель -->
                    <StatusBar Grid.Row="3" Style="{StaticResource ModernStatusBar}">
                        <StatusBarItem>
                            <TextBlock Text="{Binding StatusMessage}" 
                                       Foreground="{StaticResource DarkGrayBrush}"
                                       FontSize="12"/>
                        </StatusBarItem>
                        <Separator/>
                        <StatusBarItem HorizontalAlignment="Right">
                            <TextBlock Text="{Binding WarehouseReport.OccupancyPercentage, StringFormat='Заполненность: {0:F1}%'}" 
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontWeight="Medium"/>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>