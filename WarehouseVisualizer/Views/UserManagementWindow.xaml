<Window x:Class="WarehouseVisualizer.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление пользователями"
        Height="540"
        Width="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="{StaticResource EnterpriseBackgroundBrush}">
        <Border Style="{StaticResource EnterpriseCard}" Margin="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Пользователи и роли"
                               Style="{StaticResource PageTitleText}"
                               DockPanel.Dock="Left"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Добавить"
                                Command="{Binding DataContext.AddUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Style="{StaticResource EnterpriseButton}"/>
                        <Button Content="Редактировать"
                                Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding SelectedUser}"
                                Style="{StaticResource EnterpriseOutlineButton}"/>
                        <Button Content="Удалить"
                                Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding SelectedUser}"
                                Style="{StaticResource EnterpriseOutlineButton}"/>
                    </StackPanel>
                </DockPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          Background="#111827"
                          Foreground="{StaticResource EnterpriseTextBrush}"
                          BorderBrush="{StaticResource EnterpriseBorderBrush}"
                          GridLinesVisibility="Horizontal"
                          RowBackground="#111827"
                          AlternatingRowBackground="#172033"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="130"/>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="230"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding RoleDescription}" Width="130"/>
                        <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="80"/>
                        <DataGridTextColumn Header="Дата создания"
                                            Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                            Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="Закрыть"
                            IsCancel="True"
                            Style="{StaticResource EnterpriseOutlineButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
