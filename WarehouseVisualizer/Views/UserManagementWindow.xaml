<Window x:Class="WarehouseVisualizer.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление пользователями" 
        Height="500" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <ToolBar Grid.Row="0" Background="#F8F9FA" Padding="0,8">
            <Button Content="➕ Добавить" 
                Command="{Binding DataContext.AddUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                Background="#4A6FA5" 
                Foreground="White"
                BorderThickness="0"/>

            <Button Content="✏️ Редактировать" 
                Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding SelectedUser}"
                Background="#6B8CBC" 
                Foreground="White"
                BorderThickness="0"/>

            <Button Content="🗑️ Удалить" 
                Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding SelectedUser}"
                Background="#DC3545" 
                Foreground="White"
                BorderThickness="0"/>
        </ToolBar>

        <!-- Список пользователей -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Users}"
                  SelectedItem="{Binding SelectedUser}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="0,8,0,0"
                  SelectionMode="Single"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="120"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding RoleDescription}" Width="120"/>
                <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="60"/>
                <DataGridTextColumn Header="Дата создания" 
                                    Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" 
                                    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Закрыть" 
                    IsCancel="True" 
                    Background="Transparent"
                    BorderBrush="#DEE2E6"
                    BorderThickness="1"/>
        </StackPanel>
    </Grid>
</Window>