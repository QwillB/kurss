<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PageTitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource EnterpriseTextBrush}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style x:Key="SectionTitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource EnterpriseTextBrush}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style x:Key="MutedText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource EnterpriseMutedTextBrush}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
</ResourceDictionary>
